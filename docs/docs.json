{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Rocksky",
  "colors": {
    "primary": "#FB26BD",
    "light": "#FB26BD",
    "dark": "#C71F95"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "faq"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/jellyfin",
              "integrations/navidrome",
              "integrations/navidrome-server",
              "integrations/pano-scrobbler",
              "integrations/web-scrobbler",
              "integrations/kodi",
              "integrations/claude-desktop",
              "integrations/scrobble-api-local"
            ]
          },
          {
            "group": "Mirroring",
            "pages": [
              "mirroring/overview",
              "mirroring/lastfm",
              "mirroring/listenbrainz",
              "mirroring/tealfm"
            ]
          },
          {
            "group": "Migrating",
            "pages": [
              "migrations/from-lastfm",
              "migrations/from-listenbrainz"
            ]
          },
          {
            "group": "Rocksky CLI",
            "pages": [
              "cli/overview",
              "cli/login",
              "cli/whoami",
              "cli/nowplaying",
              "cli/scrobbles",
              "cli/scrobble",
              "cli/search",
              "cli/stats",
              "cli/artists",
              "cli/albums",
              "cli/tracks",
              "cli/create-apikey",
              "cli/sync",
              "cli/mcp",
              "cli/scrobble-api",
              "cli/help"
            ]
          }
        ]
      },
      {
        "tab": "SDKs",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "sdks/overview"
            ]
          },
          {
            "group": "Language SDKs",
            "pages": [
              "sdks/typescript",
              "sdks/python",
              "sdks/rust",
              "sdks/go",
              "sdks/ruby",
              "sdks/kotlin",
              "sdks/elixir",
              "sdks/erlang",
              "sdks/clojure",
              "sdks/gleam"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
