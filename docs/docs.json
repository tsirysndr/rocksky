            "openapi": "api-reference/openapi.json"
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "rocksky.app",
          "href": "https://rocksky.app",
          "icon": "music"
        },
        {
          "anchor": "Source",
          "href": "https://tangled.org/@rocksky.app/rocksky",
          "icon": "code"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/EVcBy2fVa3",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "/favicon.png",
