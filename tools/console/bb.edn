{:paths ["src"]
 :deps  {}

 :tasks
 {:requires ([console.core :as c])

  ;; ── meta ─────────────────────────────────────────────────────
  help    {:doc "Show all available console commands"
           :task (c/help)}
  ls      {:doc "List every registered command grouped by namespace"
           :task (c/ls)}

  ;; ── lexgen ───────────────────────────────────────────────────
  lexgen        {:doc  "Run apps/api lex gen-server"
                 :task (do (require 'console.lexgen)
                           ((resolve 'console.lexgen/server)))}
  lexgen:types  {:doc  "Generate SDK type bindings (TS/Go/Py/Rust/...)"
                 :task (do (require 'console.lexgen)
                           ((resolve 'console.lexgen/types)))}

  ;; ── api (apps/api code quality) ──────────────────────────────
  api:format    {:doc  "biome format apps/api/src. Add `fix` to write changes."
                 :task (do (require 'console.api)
                           (apply (resolve 'console.api/format) *command-line-args*))}
  api:lint      {:doc  "biome lint apps/api/src. Add `fix` to apply safe autofixes."
                 :task (do (require 'console.api)
                           (apply (resolve 'console.api/lint) *command-line-args*))}

  ;; ── db ───────────────────────────────────────────────────────
  db:migrate         {:task (do (require 'console.db) ((resolve 'console.db/migrate)))}
  db:gen-migration   {:task (do (require 'console.db) ((resolve 'console.db/gen-migration)))}
  db:pgpull          {:task (do (require 'console.db) ((resolve 'console.db/pgpull)))}
  pkl:eval           {:task (do (require 'console.db) ((resolve 'console.db/pkl-eval)))}
  pkl:gen            {:task (do (require 'console.db) ((resolve 'console.db/pkl-gen)))}

  ;; ── data ops (apps/api scripts) ──────────────────────────────
  sync          {:doc  "Sync a user's scrobbles. Usage: bb sync <did|handle>"
                 :task (do (require 'console.sync)
                           ((resolve 'console.sync/user) (first *command-line-args*)))}
  sync:library  {:task (do (require 'console.sync) ((resolve 'console.sync/library)))}
  backfill:isrc-mbid {:task (do (require 'console.sync) ((resolve 'console.sync/backfill-isrc-mbid)))}
  typesense:import   {:task (do (require 'console.sync) ((resolve 'console.sync/typesense-import)))}
  dedup        {:task (do (require 'console.sync) ((resolve 'console.sync/dedup)))}
  genres       {:task (do (require 'console.sync) ((resolve 'console.sync/genres)))}
  collections  {:task (do (require 'console.sync) ((resolve 'console.sync/collections)))}
  seed:feed    {:task (do (require 'console.sync) ((resolve 'console.sync/seed-feed)))}
  feed         {:task (do (require 'console.sync) ((resolve 'console.sync/feed)))}
  likes        {:task (do (require 'console.sync) ((resolve 'console.sync/likes)))}
  avatar       {:task (do (require 'console.sync) ((resolve 'console.sync/avatar)))}
  exp          {:task (do (require 'console.sync) ((resolve 'console.sync/exp)))}
  spotify:creds {:doc  "Register Spotify creds. Usage: bb spotify:creds <client_id> <client_secret>"
                 :task (do (require 'console.sync)
                           (apply (resolve 'console.sync/spotify-creds) *command-line-args*))}

  ;; ── daemons (Rust) ───────────────────────────────────────────
  d:connect       {:task (do (require 'console.daemons) ((resolve 'console.daemons/connect)))}
  d:dropbox       {:task (do (require 'console.daemons) ((resolve 'console.daemons/dropbox)))}
  d:googledrive   {:task (do (require 'console.daemons) ((resolve 'console.daemons/googledrive)))}
  d:jetstream     {:task (do (require 'console.daemons) ((resolve 'console.daemons/jetstream)))}
  d:playlists     {:task (do (require 'console.daemons) ((resolve 'console.daemons/playlists)))}
  d:scrobbler     {:task (do (require 'console.daemons) ((resolve 'console.daemons/scrobbler)))}
  d:spotify       {:task (do (require 'console.daemons) ((resolve 'console.daemons/spotify)))}
  d:storage       {:task (do (require 'console.daemons) ((resolve 'console.daemons/storage)))}
  d:webscrobbler  {:task (do (require 'console.daemons) ((resolve 'console.daemons/webscrobbler)))}
  d:tracklist     {:task (do (require 'console.daemons) ((resolve 'console.daemons/tracklist)))}

  ;; ── devops & dev tools ───────────────────────────────────────
  backup:ddb    {:task (do (require 'console.devops) ((resolve 'console.devops/backup-ddb)))}
  build:raichu  {:task (do (require 'console.devops) ((resolve 'console.devops/build-raichu)))}
  local-proxy   {:task (do (require 'console.devops) ((resolve 'console.devops/local-proxy)))}
  mb            {:doc "Run musicbrainz Go server"
                 :task (do (require 'console.devops) ((resolve 'console.devops/mb)))}
  cron          {:doc "Schedule a command. Usage: bb cron <interval-min> <cmd> [args...]"
                 :task (do (require 'console.cron)
                           (apply (resolve 'console.cron/schedule) *command-line-args*))}

  ;; ── env ──────────────────────────────────────────────────────
  env:load      {:doc "Load <repo>/.env (or a specific path passed as arg)."
                 :task (do (require 'console.env)
                           (if-let [p (first *command-line-args*)]
                             ((resolve 'console.env/load!) p)
                             ((resolve 'console.env/load!))))}
  env:doppler   {:doc "Pull Doppler secrets. Usage: bb env:doppler [project] [config]"
                 :task (do (require 'console.env)
                           (apply (resolve 'console.env/doppler!) *command-line-args*))}
  env:show      {:doc "Show every loaded key (masked values)."
                 :task (do (require 'console.env)
                           ;; Default `bb` invocation runs commands with an
                           ;; empty *env*; chain loads here for `bb env:show`
                           ;; to be useful as a quick diagnostic.
                           ((resolve 'console.env/load!))
                           ((resolve 'console.env/show)))}
  env:reload    {:task (do (require 'console.env) ((resolve 'console.env/reload!)))}
  env:set       {:doc  "Set one key. Usage: bb env:set <KEY> <VALUE>"
                 :task (do (require 'console.env)
                           (apply (resolve 'console.env/set!) *command-line-args*))}
  env:unset     {:doc  "Remove one key. Usage: bb env:unset <KEY>"
                 :task (do (require 'console.env)
                           (apply (resolve 'console.env/unset!) *command-line-args*))}
  env:save      {:doc  "Save current env. Usage: bb env:save [path] (default .env.local)"
                 :task (do (require 'console.env)
                           ;; For bb to be useful here, load existing env first
                           ;; so save isn't just writing out the args' edits.
                           ((resolve 'console.env/load!))
                           (apply (resolve 'console.env/save!) *command-line-args*))}

  ;; ── docker compose ───────────────────────────────────────────
  up            {:doc  "docker compose up -d (use `bb up fg` for foreground)"
                 :task (do (require 'console.docker)
                           (apply (resolve 'console.docker/up)
                                  (map keyword (filter #{"fg" "foreground"} *command-line-args*))))}
  down          {:doc  "docker compose down (`bb down v` to also drop volumes)"
                 :task (do (require 'console.docker)
                           (apply (resolve 'console.docker/down)
                                  (map keyword (filter #{"v" "volumes"} *command-line-args*))))}
  restart       {:doc  "Restart services. Usage: bb restart <svc> [svc...]"
                 :task (do (require 'console.docker)
                           (apply (resolve 'console.docker/restart) *command-line-args*))}
  logs          {:doc  "Print logs. Usage: bb logs <svc> [svc...] (add `follow` to tail)"
                 :task (do (require 'console.docker)
                           (apply (resolve 'console.docker/logs)
                                  (map (fn [a] (if (#{"follow" "f"} a) (keyword a) a))
                                       *command-line-args*)))}
  ps            {:task (do (require 'console.docker) ((resolve 'console.docker/ps)))}
  pull          {:doc  "docker compose pull [svc...]"
                 :task (do (require 'console.docker)
                           (apply (resolve 'console.docker/pull) *command-line-args*))}
  exec          {:doc  "Exec inside a service. Usage: bb exec <svc> <cmd> [args...]"
                 :task (do (require 'console.docker)
                           (apply (resolve 'console.docker/exec) *command-line-args*))}}}
