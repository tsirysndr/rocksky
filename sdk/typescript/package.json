{
  "name": "@rocksky/sdk",
  "version": "0.7.0",
  "description": "TypeScript SDK for Rocksky \u2014 built on atcute: AppView reads, AT Protocol PDS writes (scrobble, like, follow, shout), a local dedup index, and Jetstream real-time sync.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsirysndr/rocksky.git",
    "directory": "sdk/typescript"
  },
  "homepage": "https://github.com/tsirysndr/rocksky/tree/main/sdk/typescript#readme",
  "bugs": {
    "url": "https://github.com/tsirysndr/rocksky/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node --format esm --external none && bun run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "example": "bun run examples/native.ts"
  },
  "keywords": [
    "rocksky",
    "atproto",
    "at-protocol",
    "bluesky",
    "xrpc",
    "scrobble",
    "scrobbling",
    "music",
    "lastfm",
    "now-playing",
    "sdk",
    "typescript",
    "client",
    "api"
  ],
  "devDependencies": {
    "@atcute/atproto": "^4.0.3",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "@atcute/car": "^6.0.2",
    "@atcute/cbor": "^2.3.6",
    "@atcute/cid": "^2.4.2",
    "@atcute/client": "^5.1.1",
    "@atcute/identity": "^2.0.2",
    "@atcute/identity-resolver": "^2.0.1",
    "@atcute/password-session": "^1.0.2",
    "classic-level": "^3.0.0"
  }
}
