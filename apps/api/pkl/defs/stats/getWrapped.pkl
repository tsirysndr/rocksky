amends "../../schema/lexicon.pkl"

lexicon = 1
id = "app.rocksky.stats.getWrapped"
defs = new Mapping<String, Query> {
  ["main"] {
    type = "query"
    description = "Get a user's year-in-review Wrapped stats"
    parameters = new Params {
      required = List("did")
      properties {
        ["did"] = new StringType {
          description = "The DID or handle of the user"
          format = "at-identifier"
        }
        ["year"] = new IntegerType {
          type = "integer"
          description = "The year to get wrapped stats for (defaults to current year)"
          minimum = 2000
        }
      }
    }
    output {
      encoding = "application/json"
      schema = new Ref {
        type = "ref"
        ref = "app.rocksky.stats.defs#wrappedView"
      }
    }
  }
}
