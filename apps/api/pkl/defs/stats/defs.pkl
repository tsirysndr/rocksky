amends  "../../schema/lexicon.pkl"

lexicon = 1
id = "app.rocksky.stats.defs"
defs = new Mapping<String, ObjectType> {
  ["statsView"] {
    type = "object"
    properties {
      ["scrobbles"] = new IntegerType {
        type = "integer"
        description = "The total number of scrobbles."
      }
      ["artists"] = new IntegerType {
        type = "integer"
        description = "The total number of unique artists scrobbled."
      }
      ["lovedTracks"] = new IntegerType {
        type = "integer"
        description = "The total number of tracks marked as loved."
      }
      ["albums"] = new IntegerType {
        type = "integer"
        description = "The total number of unique albums scrobbled."
      }
      ["tracks"] = new IntegerType {
        type = "integer"
        description = "The total number of unique tracks scrobbled."
      }
    }
  }

  ["globalStatsView"] {
    type = "object"
    properties {
      ["scrobbles"] = new IntegerType {
        type = "integer"
        description = "Total scrobbles across all users on Rocksky."
      }
      ["users"] = new IntegerType {
        type = "integer"
        description = "Total number of users on Rocksky."
      }
      ["artists"] = new IntegerType {
        type = "integer"
        description = "Total number of artists known to Rocksky."
      }
      ["albums"] = new IntegerType {
        type = "integer"
        description = "Total number of albums known to Rocksky."
      }
      ["tracks"] = new IntegerType {
        type = "integer"
        description = "Total number of tracks known to Rocksky."
      }
    }
  }

  ["wrappedArtist"] {
    type = "object"
    properties {
      ["id"] = new StringType { description = "The unique identifier of the artist." }
      ["name"] = new StringType { description = "The name of the artist." }
      ["picture"] = new StringType { description = "The picture URL of the artist." }
      ["uri"] = new StringType { description = "The AT-URI of the artist." format = "at-uri" }
      ["playCount"] = new IntegerType { description = "Number of plays in the wrapped period." minimum = 0 }
    }
  }

  ["wrappedTrack"] {
    type = "object"
    properties {
      ["id"] = new StringType { description = "The unique identifier of the track." }
      ["title"] = new StringType { description = "The title of the track." }
      ["artist"] = new StringType { description = "The artist of the track." }
      ["albumArt"] = new StringType { description = "The album art URL." }
      ["uri"] = new StringType { description = "The AT-URI of the track." format = "at-uri" }
      ["artistUri"] = new StringType { description = "The AT-URI of the artist." format = "at-uri" }
      ["albumUri"] = new StringType { description = "The AT-URI of the album." format = "at-uri" }
      ["playCount"] = new IntegerType { description = "Number of plays in the wrapped period." minimum = 0 }
    }
  }

  ["wrappedAlbum"] {
    type = "object"
    properties {
      ["id"] = new StringType { description = "The unique identifier of the album." }
      ["title"] = new StringType { description = "The title of the album." }
      ["artist"] = new StringType { description = "The artist of the album." }
      ["albumArt"] = new StringType { description = "The album art URL." }
      ["uri"] = new StringType { description = "The AT-URI of the album." format = "at-uri" }
      ["playCount"] = new IntegerType { description = "Number of plays in the wrapped period." minimum = 0 }
    }
  }

  ["wrappedGenreCount"] {
    type = "object"
    properties {
      ["genre"] = new StringType { description = "The genre name." }
      ["count"] = new IntegerType { description = "Number of scrobbles for this genre." minimum = 0 }
    }
  }

  ["wrappedMonthCount"] {
    type = "object"
    properties {
      ["month"] = new IntegerType { description = "Month number (1-12)." minimum = 1 maximum = 12 }
      ["count"] = new IntegerType { description = "Number of scrobbles in this month." minimum = 0 }
    }
  }

  ["wrappedDayCount"] {
    type = "object"
    properties {
      ["date"] = new StringType { description = "The date (YYYY-MM-DD)." }
      ["count"] = new IntegerType { description = "Number of scrobbles on this day." minimum = 0 }
    }
  }

  ["wrappedMilestone"] {
    type = "object"
    properties {
      ["trackTitle"] = new StringType { description = "The title of the track." }
      ["artistName"] = new StringType { description = "The name of the artist." }
      ["timestamp"] = new StringType { description = "The timestamp of the scrobble." format = "datetime" }
      ["trackUri"] = new StringType { description = "AT-URI of the track record, used to build a clickable link to the song page." format = "at-uri" }
    }
  }

  ["wrappedView"] {
    type = "object"
    properties {
      ["year"] = new IntegerType { description = "The year of the wrapped stats." }
      ["totalScrobbles"] = new IntegerType { description = "Total scrobbles in the year." minimum = 0 }
      ["totalListeningTimeMinutes"] = new IntegerType { description = "Total listening time in minutes." minimum = 0 }
      ["topArtists"] = new Array {
        type = "array"
        description = "Top 5 artists by play count."
        items = new Ref { ref = "app.rocksky.stats.defs#wrappedArtist" }
      }
      ["topTracks"] = new Array {
        type = "array"
        description = "Top 5 tracks by play count."
        items = new Ref { ref = "app.rocksky.stats.defs#wrappedTrack" }
      }
      ["topAlbums"] = new Array {
        type = "array"
        description = "Top 5 albums by play count."
        items = new Ref { ref = "app.rocksky.stats.defs#wrappedAlbum" }
      }
      ["topGenres"] = new Array {
        type = "array"
        description = "Top genres by play count."
        items = new Ref { ref = "app.rocksky.stats.defs#wrappedGenreCount" }
      }
      ["scrobblesPerMonth"] = new Array {
        type = "array"
        description = "Scrobble counts per month."
        items = new Ref { ref = "app.rocksky.stats.defs#wrappedMonthCount" }
      }
      ["mostActiveDay"] = new Ref {
        ref = "app.rocksky.stats.defs#wrappedDayCount"
        description = "The most active day of the year."
      }
      ["mostActiveHour"] = new IntegerType {
        description = "The most active hour of the day (0-23)."
        minimum = 0
        maximum = 23
      }
      ["newArtistsCount"] = new IntegerType {
        description = "Number of artists heard for the first time this year."
        minimum = 0
      }
      ["longestStreak"] = new IntegerType {
        description = "Longest consecutive days streak."
        minimum = 0
      }
      ["firstScrobble"] = new Ref {
        ref = "app.rocksky.stats.defs#wrappedMilestone"
        description = "The first scrobble of the year."
      }
      ["lastScrobble"] = new Ref {
        ref = "app.rocksky.stats.defs#wrappedMilestone"
        description = "The last scrobble of the year."
      }
    }
  }
}