amends "../../schema/lexicon.pkl"

lexicon = 1
id = "app.rocksky.library.createPlaylist"
defs = new Mapping<String, Procedure> {
  ["main"] {
    type = "procedure"
    description = "Create a new playlist."
    input {
      encoding = "application/json"
      schema {
        type = "object"
        required = List("name")
        properties {
          ["name"] = new StringType {
            type = "string"
            description = "The playlist name."
          }
        }
      }
    }
    output {
      encoding = "application/json"
      schema = new ObjectType {
        type = "object"
        properties {}
      }
    }
  }
}
