amends "../../schema/lexicon.pkl"

lexicon = 1
id = "app.rocksky.library.unstar"
defs = new Mapping<String, Procedure> {
  ["main"] {
    type = "procedure"
    description = "Remove a star from a song, album or artist."
    input {
      encoding = "application/json"
      schema {
        type = "object"
        required = List("id")
        properties {
          ["id"] = new StringType {
            type = "string"
            description = "The song id to unstar."
          }
          ["albumId"] = new StringType {
            type = "string"
            description = "An album id to unstar."
          }
          ["artistId"] = new StringType {
            type = "string"
            description = "An artist id to unstar."
          }
        }
      }
    }
    output {
      encoding = "application/json"
      schema = new ObjectType {
        type = "object"
        properties {}
      }
    }
  }
}
