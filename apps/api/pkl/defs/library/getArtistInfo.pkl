amends "../../schema/lexicon.pkl"

lexicon = 1
id = "app.rocksky.library.getArtistInfo"
defs = new Mapping<String, Query> {
  ["main"] {
    type = "query"
    description = "Get artist biography, images and similar artists."
    parameters {
      type = "params"
      required = List("id")
      properties {
        ["id"] = new StringType {
          type = "string"
          description = "The artist id"
        }
      }
    }
    output {
      encoding = "application/json"
      schema = new ObjectType {
        type = "object"
        properties {}
      }
    }
  }
}
