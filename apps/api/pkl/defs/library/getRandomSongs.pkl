amends "../../schema/lexicon.pkl"

lexicon = 1
id = "app.rocksky.library.getRandomSongs"
defs = new Mapping<String, Query> {
  ["main"] {
    type = "query"
    description = "Get a list of random songs."
    parameters {
      type = "params"
      properties {
        ["size"] = new IntegerType {
          type = "integer"
          description = "Number of songs to return (max 500)."
        }
        ["genre"] = new StringType {
          type = "string"
          description = "Only return songs in this genre."
        }
        ["fromYear"] = new IntegerType {
          type = "integer"
          description = "Only return songs published after or in this year."
        }
        ["toYear"] = new IntegerType {
          type = "integer"
          description = "Only return songs published before or in this year."
        }
      }
    }
    output {
      encoding = "application/json"
      schema = new ObjectType {
        type = "object"
        properties {}
      }
    }
  }
}
