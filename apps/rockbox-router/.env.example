# --- Required ---
FLY_API_TOKEN=fly_machines_token_here
FLY_APP=rockbox
ROUTER_POSTGRES_URL=postgresql://user:pass@host/db

# --- Optional ---
# Shared secret the CF Worker (or any upstream) must present.
# Leave empty for local dev.
ROUTER_AUTH_BEARER=

ROCKBOX_IMAGE=tsiry/rockbox:latest
FLY_DEFAULT_REGION=iad
MACHINE_CPU_KIND=shared
MACHINE_CPUS=1
MACHINE_MEMORY_MB=512
MACHINE_INTERNAL_PORT=8080
PORT=8080
